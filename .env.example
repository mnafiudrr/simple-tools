# Browserless v2.51.0 base URL for PNG rasterization (return_type=png).
# Bake the API token into the URL for Browserless Cloud, e.g.:
#   https://chrome.browserless.io?token=YOUR_TOKEN
BROWSERLESS_URL=http://localhost:3000

# Public origin of this Worker. Browserless loads {PAGE_URL}/qr?<query> (with
# return_type stripped) to render the SVG.
PAGE_URL=http://localhost:8787